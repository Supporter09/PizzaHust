            "$ref": "#/components/schemas/AuthUserResponse"
          }
        },
        "required": [
          "message",
          "user"
        ],
        "title": "AuthResponse",
        "type": "object"
      },
      "AuthUserResponse": {
        "properties": {
          "current_points": {
            "title": "Current Points",
            "type": "integer"
          },
          "full_name": {
            "title": "Full Name",
            "type": "string"
          },
          "membership_tier": {
            "title": "Membership Tier",
            "type": "string"
          },
          "phone_number": {
            "title": "Phone Number",
            "type": "string"
          },
          "role": {
            "title": "Role",
            "type": "string"
          },
          "total_points_earned": {
            "title": "Total Points Earned",
            "type": "integer"
          },
          "user_id": {
            "title": "User Id",
            "type": "integer"
          }
        },
        "required": [
          "user_id",
          "full_name",
          "phone_number",
          "role",
          "membership_tier",
          "current_points",
          "total_points_earned"
