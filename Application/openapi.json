          "id",
          "slug",
          "name",
          "description",
          "category",
          "price_vnd",
          "image_url",
          "sizes",
          "crusts"
        ],
        "title": "MenuItemResponse",
        "type": "object"
      },
      "MenuOptionResponse": {
        "properties": {
          "label": {
            "title": "Label",
            "type": "string"
          },
          "price_delta_vnd": {
            "title": "Price Delta Vnd",
            "type": "integer"
          },
          "value": {
            "title": "Value",
            "type": "string"
          }
        },
        "required": [
          "value",
          "label",
          "price_delta_vnd"
        ],
        "title": "MenuOptionResponse",
        "type": "object"
      },
      "RegisterRequest": {
        "properties": {
          "address": {
            "anyOf": [
              {
                "maxLength": 255,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Address"
          },
          "full_name": {
            "maxLength": 100,
            "minLength": 1,
            "title": "Full Name",
            "type": "string"
          },
          "password": {
            "maxLength": 255,
            "minLength": 8,
            "title": "Password",
            "type": "string"
          },
