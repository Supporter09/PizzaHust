        "title": "AuthUserResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "LoginRequest": {
        "properties": {
          "password": {
            "maxLength": 255,
            "minLength": 1,
            "title": "Password",
            "type": "string"
          },
          "phone_number": {
            "maxLength": 15,
            "minLength": 9,
            "title": "Phone Number",
            "type": "string"
          }
        },
        "required": [
          "phone_number",
          "password"
        ],
        "title": "LoginRequest",
        "type": "object"
      },
      "MenuItemResponse": {
        "properties": {
          "badge": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Badge"
          },
          "category": {
            "title": "Category",
            "type": "string"
          },
          "crusts": {
            "items": {
              "$ref": "#/components/schemas/MenuOptionResponse"
            },
            "title": "Crusts",
            "type": "array"
          },
          "description": {
            "title": "Description",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "image_url": {
            "title": "Image Url",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "price_vnd": {
            "title": "Price Vnd",
            "type": "integer"
