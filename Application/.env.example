# Copy to .env and edit. Never commit .env.

# Backend
DATABASE_URL=mysql+pymysql://pizza:pizza@mysql:3306/pizzahust
SESSION_SECRET=change-me-32-bytes-minimum
FRONTEND_ORIGIN=http://localhost:3000
MYSQL_HOST_PORT=33306

# WARNING: dev-only seed credentials. These provision privileged admin/kitchen
# logins — set strong, unique values in any shared or deployed environment.
# Compose and the seed script require these to be present (they fail if unset).
ADMIN_SEED_PHONE=0900000001
ADMIN_SEED_PASSWORD=admin123
KITCHEN_SEED_PHONE=0900000002
KITCHEN_SEED_PASSWORD=kitchen123

# Product image uploads (A1). Dir is mounted as a named volume in compose so
# uploads survive container rebuilds; served at IMAGE_BASE_URL via StaticFiles.
IMAGE_UPLOAD_DIR=/data/images
IMAGE_BASE_URL=/images
IMAGE_MAX_BYTES=5242880

# Delivery integration
DELIVERY_PROVIDER=mock
DELIVERY_BASE_URL=http://delivery-mock:9000
DELIVERY_API_KEY=dev-api-key
DELIVERY_WEBHOOK_SECRET=dev-mock-secret-change-me
DELIVERY_TIMEOUT_SECONDS=5
DELIVERY_PICKUP_ADDRESS=PizzaHUST, Hoan Kiem, Ha Noi

# Business constants (single source of truth, mirrored in PRODUCT.md)
DELIVERY_FEE_VND=22000
LOYALTY_ACCRUAL_RATE=10000
LOYALTY_REDEEM_VALUE_VND=1000
LOYALTY_MAX_REDEEM_PCT=0.5
ORDER_PROMISED_TIME_DEFAULT_MIN=45

# Frontend (only NEXT_PUBLIC_* is exposed to the browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
