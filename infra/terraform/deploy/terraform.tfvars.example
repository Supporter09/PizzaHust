# zone         = "asia-southeast1-a"
# machine_type = "e2-medium"
# repo_url     = "https://github.com/Supporter09/PizzaHust.git"
# network_name = "mk8s-poc-net"
# subnet_name  = "mk8s-poc-subnet"
