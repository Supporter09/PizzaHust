# Copy to terraform.tfvars (gitignored) and fill in.
project_id = "your-project-id"
domain     = "your.domain.example"

# Full IAM principals - NOT bare emails. These are PII; keep them only in the
# gitignored terraform.tfvars, never in committed files.
iap_allowed_members = [
  "user:someone@gmail.com",
]

